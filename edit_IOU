double calcIoU(
  const sensor_msgs::msg::RegionOfInterest & roi_1, // Camera ROI
  const sensor_msgs::msg::RegionOfInterest & roi_2) // Projected LiDAR ROI
{
  // --- ADD PADDING HERE ---
  int padding_x = 30; // 30 pixel tolerance for horizontal TF error
  int padding_y = 15; // 15 pixel tolerance for vertical TF error

  double s_1, s_2;
  // Use the ORIGINAL size for s_1/s_2 so the IoU ratio stays sane, 
  // or use the padded size if you want to be even more aggressive.
  s_1 = static_cast<double>(roi_1.width * roi_1.height);
  s_2 = static_cast<double>(roi_2.width * roi_2.height);

  double overlap_min_x, overlap_min_y, overlap_max_x, overlap_max_y;

  // Apply padding to the "boundaries" of the camera ROI (roi_1)
  double r1_min_x = static_cast<double>(roi_1.x_offset) - padding_x;
  double r1_min_y = static_cast<double>(roi_1.y_offset) - padding_y;
  double r1_max_x = static_cast<double>(roi_1.x_offset + roi_1.width) + padding_x;
  double r1_max_y = static_cast<double>(roi_1.y_offset + roi_1.height) + padding_y;

  overlap_min_x = r1_min_x < roi_2.x_offset ? roi_2.x_offset : r1_min_x;
  overlap_min_y = r1_min_y < roi_2.y_offset ? roi_2.y_offset : r1_min_y;
  overlap_max_x = r1_max_x < roi_2.x_offset + roi_2.width
                    ? r1_max_x
                    : roi_2.x_offset + roi_2.width;
  overlap_max_y = r1_max_y < roi_2.y_offset + roi_2.height
                    ? r1_max_y
                    : roi_2.y_offset + roi_2.height;

  double overlap_w = overlap_max_x - overlap_min_x;
  double overlap_h = overlap_max_y - overlap_min_y;

  if (overlap_w <= 0 || overlap_h <= 0) {
    return 0.0;
  }

  double overlap_s = overlap_w * overlap_h;
  return overlap_s / (s_1 + s_2 - overlap_s);
}
